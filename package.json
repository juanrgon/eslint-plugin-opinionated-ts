{
  "name": "eslint-plugin-opinionated-ts",
  "version": "0.2.0",
  "description": "Personal ESLint rules for opinionated TypeScript: single args parameter, inferred return types, no enums, satisfies over as, type over interface",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juanrgon/eslint-plugin-opinionated-ts.git"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "npm run build && eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0",
    "eslint-plugin-unicorn": "^63.0.0"
  }
}
